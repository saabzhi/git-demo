        remote_src: true
        mode: preserve
      when: service_stop_status.stdout | int == 1
      ignore_errors: true

    # 添加删除上一个旧版本的任务
    - name: 获取上一个备份目录列表
      find:
        paths: /opt/app/backup
        file_type: directory
        recurse: false
        age: +1d  # 超过1天的目录
      register: old_backup_dirs
      when: service_stop_status.stdout | int == 1

    - name: 删除上一个旧版本备份目录
      file:
        path: "{{ item.path }}"
        state: absent
      loop: "{{ old_backup_dirs.files }}"
      when: service_stop_status.stdout | int == 1 and old_backup_dirs.matched > 0

