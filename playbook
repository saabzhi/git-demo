if __name__ == "__main__":
    # [修改点 1]: 填入你存放 A表、B表、C表的实际文件夹物理路径
    # 例如 Windows 路径写成: r"D:\excel_factory"
    SOURCE_DIRECTORY = "./my_excel_files"

